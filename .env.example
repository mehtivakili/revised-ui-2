# WooCommerce catalog sync (server-side only; never use NEXT_PUBLIC_)
WOOCOMMERCE_URL=https://ddcpersia.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
# Use 1 when WooCommerce prices are Toman; use 10 when they are Rial.
WOOCOMMERCE_PRICE_DIVISOR=1
# Optional comma-separated CDN hosts used by WooCommerce product images.
WOOCOMMERCE_IMAGE_HOSTS=
# Optional absolute path; defaults to public/catalog-cache.
CATALOG_IMAGE_DIR=
