DATABASE_URL=
AUTH_SECRET=
PASSWORD_SECRET=
MELIPAYAMAK_SHARED_API_KEY=
MELIPAYAMAK_SHARED_BODY_ID=495367
# Optional: complete /api/send/shared/... URL copied from the console.
MELIPAYAMAK_SHARED_URL=
OTP_TTL_SECONDS=120
OTP_RATE_LIMIT_WINDOW_SECONDS=600
OTP_RATE_LIMIT_MAX=5
